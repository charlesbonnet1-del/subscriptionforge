# ── SubscriptionForge — variables d'environnement ──
# Copiez ce fichier en .env.local et renseignez vos valeurs.
# Tout est OPTIONNEL au lancement : sans ces clés, l'app tourne en mode "tout ouvert".

# Supabase (base + auth + back office)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Fournisseur vidéo : mux | cloudflare | bunny  (laisser vide = stub)
VIDEO_PROVIDER=

# Mux (si VIDEO_PROVIDER=mux)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_SIGNING_KEY_ID=
MUX_SIGNING_PRIVATE_KEY=

# Cloudflare Stream (si VIDEO_PROVIDER=cloudflare)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_TOKEN=

# Bunny Stream (si VIDEO_PROVIDER=bunny)
BUNNY_LIBRARY_ID=
BUNNY_API_KEY=

# Stripe (paywall — à venir)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
